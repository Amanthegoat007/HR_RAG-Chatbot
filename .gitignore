# ============================================================================
# FILE: .gitignore
# PURPOSE: Prevent sensitive files and build artifacts from being committed
# ============================================================================

# --- Secrets (NEVER commit these) ---
.env
*.key
*.pem
*.crt
# Keep .env.example (it's a template with no real values)
!.env.example

# --- LLM Model files (too large for git, use download_model.sh) ---
services/llm/models/*.gguf
services/llm/models/*.bin
# Keep the .gitkeep placeholder
!services/llm/models/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg-info/
dist/
build/
venv/
.venv/
env/
.env/

# --- IDE & OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
# Do NOT ignore Dockerfiles — they must be committed
# Ignore any local docker volumes/data accidentally placed in repo
docker-data/
postgres-data/

# --- Generated files ---
# The traceability matrix is generated by utils/generate_traceability.py
# Commit the generated xlsx to repo for stakeholder visibility
# HR_RAG_Traceability_Matrix.xlsx  # Uncomment to exclude from git

# --- Logs ---
*.log
*_logs.txt
*_build*.log
compose_build*.log
logs/

# --- Monitoring data ---
grafana-data/
prometheus-data/

# --- Node (if any frontend tooling is added later) ---
node_modules/
