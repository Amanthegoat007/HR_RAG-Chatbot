# ============================================================================
# FILE: .env.example
# PURPOSE: Template for ALL environment variables used by the HR RAG Chatbot.
#          Copy this file to .env and fill in your actual values.
#          NEVER commit the .env file to version control.
# ARCHITECTURE REF: §9 — Security Implementation
# USAGE: Windows: Copy-Item .env.example .env
#        Linux/Mac: cp .env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# SECURITY — JWT Authentication (Architecture §9)
# ---------------------------------------------------------------------------
# Strong HS256 secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_256bit_secret_key_here

# Password hashes for the two static accounts (Admin + Employee)
# Generate with: python utils/hash_password.py <your_password>
# bcrypt cost factor 12 is enforced in auth_service.py
ADMIN_PASSWORD_HASH=$2b$12$CHANGEME_replace_with_bcrypt_hash_of_admin_password
USER_PASSWORD_HASH=$2b$12$CHANGEME_replace_with_bcrypt_hash_of_user_password

# Static usernames (do NOT change — these are the only two accounts)
ADMIN_USERNAME=hr_admin
USER_USERNAME=hr_user

# JWT token expiry in hours (default: 8 hours as per architecture)
JWT_EXPIRY_HOURS=8

# ---------------------------------------------------------------------------
# POSTGRESQL — Metadata, Audit Log, Job Status (Architecture §5)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hr_rag_db
POSTGRES_USER=hr_rag_user
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Full DSN used by asyncpg in Python services
POSTGRES_DSN=postgresql://hr_rag_user:CHANGE_ME_strong_postgres_password@postgres:5432/hr_rag_db

# ---------------------------------------------------------------------------
# REDIS — Semantic Cache + Celery Broker (Architecture §6.2)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery broker uses DB 1 to separate from cache DB 0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Semantic cache settings
CACHE_SIMILARITY_THRESHOLD=0.92    # Minimum cosine similarity to consider a cache hit
CACHE_MAX_ENTRIES=1000             # Maximum number of cached query-answer pairs (LRU)
CACHE_TTL_SECONDS=86400            # Cache entry TTL: 24 hours

# ---------------------------------------------------------------------------
# MINIO — Document Object Storage (Architecture §5.3)
# ---------------------------------------------------------------------------
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_BUCKET_NAME=hr-documents     # Bucket for original files + markdown intermediates
MINIO_ENDPOINT_URL=http://minio:9000

# ---------------------------------------------------------------------------
# QDRANT — Vector Database (Architecture §4.1)
# ---------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=hr_documents     # Name of the collection storing chunk embeddings

# ---------------------------------------------------------------------------
# EMBEDDING SERVICE — BAAI/bge-m3 (Architecture §3.3)
# ---------------------------------------------------------------------------
EMBEDDING_SVC_URL=http://embedding-svc:8004
EMBEDDING_MODEL_NAME=BAAI/bge-m3   # HuggingFace model ID
EMBEDDING_BATCH_SIZE=32            # Batch size for inference (CPU-optimized)
EMBEDDING_DENSE_DIM=1024           # BGE-M3 dense vector dimension

# ---------------------------------------------------------------------------
# RERANKER SERVICE — BAAI/bge-reranker-v2-m3 (Architecture §4.2)
# ---------------------------------------------------------------------------
RERANKER_SVC_URL=http://reranker-svc:8005
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5                   # Return top-N chunks after reranking (from 20 candidates)
HF_HUB_DISABLE_XET=1               # Disable Xet path (more stable in restricted networks)
HF_HUB_ENABLE_HF_TRANSFER=1        # Use hf_transfer accelerated downloader
MODEL_PREFETCH_ON_STARTUP=true     # Prefetch embedding+reranker models before FastAPI bind
MODEL_DOWNLOAD_WORKERS=16          # Parallel download workers for Hugging Face snapshots

# ---------------------------------------------------------------------------
# LLM SERVER — Mistral-7B-Instruct-v0.3 via llama.cpp (Architecture §3.2)
# ---------------------------------------------------------------------------
# LLM_PROVIDER controls which backend is used:
#   local       = llama.cpp on-premises server (default, no internet needed)
#   azure_openai = Azure OpenAI API (fallback, requires AZURE_* vars below)
#   openai      = OpenAI API (fallback, requires OPENAI_API_KEY below)
LLM_PROVIDER=local

# Local llama.cpp server URL (service name resolves within Docker network)
LOCAL_LLM_URL=http://llm-server:8080
LLM_MODEL_FILE=mistral-7b-instruct-v0.3.Q5_K_M.gguf

# LLM generation parameters
LLM_MAX_TOKENS=1024                # Maximum tokens to generate per response
LLM_MAX_TOKENS_SHORT=120           # Adaptive budget for short factual responses
LLM_MAX_TOKENS_MEDIUM=180          # Adaptive budget for list/policy responses
LLM_MAX_TOKENS_LONG=256            # Adaptive budget for explanation responses
LLM_TEMPERATURE=0.1                # Low temperature for factual HR answers (0=deterministic)
LLM_STOP_SEQUENCE=<END_ANSWER>     # Strict stop marker for clean response endings
LLM_ADAPTIVE_TOKENS_ENABLED=true   # Enable per-query token budget selection
LLM_CONTEXT_SIZE=4096              # Context window per parallel slot (matches --ctx-size)
LLM_PARALLEL_SLOTS=4              # Concurrent KV-cache slots (matches --parallel)
LLM_TIMEOUT_SECONDS=60            # Request timeout before 504 error
PROMPT_MAX_CHUNKS=2               # Max context chunks sent to LLM prompt
PROMPT_MAX_CHUNK_CHARS=450        # Max chars per chunk sent to LLM prompt
PROMPT_MAX_CHUNK_SENTENCES=4      # Max extracted sentences per context chunk

# ---------------------------------------------------------------------------
# AZURE OPENAI FALLBACK — Optional (Architecture §2, Cloud Fallback)
# ---------------------------------------------------------------------------
# Only required when LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=CHANGE_ME_or_leave_blank_if_not_using
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o    # Your Azure deployment name
AZURE_OPENAI_API_VERSION=2024-02-01

# ---------------------------------------------------------------------------
# OPENAI FALLBACK — Optional (Architecture §2, Cloud Fallback)
# ---------------------------------------------------------------------------
# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME_or_leave_blank_if_not_using
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# DOCUMENT PROCESSING — Ingest Service (Architecture §3.1)
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=200              # Maximum file upload size (matches Nginx limit)
SUPPORTED_FORMATS=pdf,docx,xlsx,pptx,txt,md
CHUNK_SIZE_TOKENS=256               # Semantic chunk size in tokens
CHUNK_OVERLAP_TOKENS=64             # Overlap between consecutive chunks
TESSERACT_LANG=eng+ara              # OCR languages: English + Arabic

# ---------------------------------------------------------------------------
# RETRIEVAL PIPELINE (Architecture §4.1)
# ---------------------------------------------------------------------------
RETRIEVAL_DENSE_TOP_K=15            # Dense ANN search: retrieve top-15 candidates
RETRIEVAL_SPARSE_TOP_K=15          # Sparse BM25 search: retrieve top-15 candidates
RETRIEVAL_RERANK_TOP_N=20          # Send top-20 (after RRF) to reranker
RRF_K_CONSTANT=60                  # Reciprocal Rank Fusion constant (standard = 60)

# ---------------------------------------------------------------------------
# SERVICE PORTS (internal, used for health checks and inter-service calls)
# ---------------------------------------------------------------------------
AUTH_SVC_PORT=8001
QUERY_SVC_PORT=8002
INGEST_SVC_PORT=8003
EMBEDDING_SVC_PORT=8004
RERANKER_SVC_PORT=8005
LLM_SERVER_PORT=8080

# ---------------------------------------------------------------------------
# MONITORING — Prometheus + Grafana (Architecture §10)
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
PROMETHEUS_RETENTION_DAYS=15       # How long Prometheus retains metrics

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json                     # json (structured, for Grafana) or text (human-readable)

# ---------------------------------------------------------------------------
# NGINX SSL (Architecture §9)
# ---------------------------------------------------------------------------
# For production: replace with real certificate paths
SSL_CERT_PATH=./nginx/ssl/server.crt
SSL_KEY_PATH=./nginx/ssl/server.key
NGINX_RATE_LIMIT=10r/s             # Rate limit per IP address
